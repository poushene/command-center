<plist version="1.0">
<dict>

    <key>Label</key>
    <string>com.command-center.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/serj/command-center/command_center.py</string>
